{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["hnd1"],
  "crons": [
    { "path": "/api/cron/post-sns", "schedule": "0 21 * * *" }
  ],
  "headers": [
    {
      "source": "/feed.xml",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600" }]
    }
  ]
}
